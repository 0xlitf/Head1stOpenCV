<procedure name="get_calib_factor">
<interface>
<io>
<par name="ImageCalib"/>
</io>
<oc>
<par name="scale_factor"/>
</oc>
</interface>
<body>
<l>CaltabName := 'caltab_HC7-50-2.5.descr'</l>
<l>gen_caltab(7, 7, 0.005, 0.5, CaltabName, 'caltab.ps')</l>
<l>SizeGauss := 3</l>
<l>MarkThresh := 200</l>
<l>MinDiamMarks := 3</l>
<l>try</l>
<l>    find_caltab (ImageCalib, Caltab, CaltabName, SizeGauss, MarkThresh, MinDiamMarks)</l>
<l>    dev_set_color ('green')</l>
<l>    dev_display (Caltab)</l>
<l>    scale_factor := 1.0</l>
<l>    smallest_rectangle2(Caltab, Row, Column, Phi1, Length11, Length21)</l>
<l>    if(Length11[0] &gt; 0)</l>
<l>        scale_factor := (40-1.25*2)/(Length11*2)</l>
<l>    endif</l>
<l>catch(e)</l>
<l>    disp_message(3600, e[2], 'window', 10, 10, 'black', 'true')</l>
<l>endtry</l>
<c></c>
<l>return ()</l>
</body>
<docu id="get_calib_factor">
<parameters>
<parameter id="ImageCalib"/>
<parameter id="scale_factor"/>
</parameters>
</docu>
</procedure>
</hdevelop>
