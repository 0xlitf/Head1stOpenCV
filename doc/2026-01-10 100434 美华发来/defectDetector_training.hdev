<procedure name="set_display_font">
<interface>
<ic>
<par name="WindowHandle"/>
<par name="Size"/>
<par name="Font"/>
<par name="Bold"/>
<par name="Slant"/>
</ic>
</interface>
<body>
<c>* This procedure sets the text font of the current window with</c>
<c>* the specified attributes.</c>
<c>* It is assumed that following fonts are installed on the system:</c>
<c>* Windows: Courier New, Arial Times New Roman</c>
<c>* Linux: courier, helvetica, times</c>
<c>* Because fonts are displayed smaller on Linux than on Windows,</c>
<c>* a scaling factor of 1.25 is used the get comparable results.</c>
<c>* For Linux, only a limited number of font sizes is supported,</c>
<c>* to get comparable results, it is recommended to use one of the</c>
<c>* following sizes: 9, 11, 14, 16, 20, 27</c>
<c>* (which will be mapped internally on Linux systems to 11, 14, 17, 20, 25, 34)</c>
<c>* </c>
<c>* input parameters:</c>
<c>* WindowHandle: The graphics window for which the font will be set</c>
<c>* Size: The font size. If Size=-1, the default of 16 is used.</c>
<c>* Bold: If set to 'true', a bold font is used</c>
<c>* Slant: If set to 'true', a slanted font is used</c>
<c>* </c>
<l>get_system ('operating_system', OS)</l>
<l>if (Size=[] or Size=-1)</l>
<l>    Size := 16</l>
<l>endif</l>
<l>if (OS{0:2}='Win')</l>
<c>    * set font on Windows systems</c>
<l>    if (Font = 'mono' or Font = 'Courier' or Font = 'courier')</l>
<l>        Font := 'Courier New'</l>
<l>    elseif (Font = 'sans')</l>
<l>        Font := 'Arial'</l>
<l>    elseif (Font = 'serif')</l>
<l>        Font := 'Times New Roman'</l>
<l>    endif</l>
<l>    if (Bold='true')</l>
<l>        Bold := 1</l>
<l>    elseif (Bold='false')</l>
<l>        Bold := 0</l>
<l>    else</l>
<l>        Exception := 'Wrong value of control parameter Bold'</l>
<l>        throw (Exception)</l>
<l>    endif</l>
<l>    if (Slant='true')</l>
<l>        Slant := 1</l>
<l>    elseif (Slant='false')</l>
<l>        Slant := 0</l>
<l>    else</l>
<l>        Exception := 'Wrong value of control parameter Slant'</l>
<l>        throw (Exception)</l>
<l>    endif</l>
<l>    try</l>
<l>        set_font (WindowHandle, '-' + Font + '-' + Size + '-*-' + Slant + '-*-*-' + Bold +'-')</l>
<l>    catch (Exception)</l>
<l>        throw (Exception)</l>
<l>    endtry</l>
<l>else</l>
<c>    * set font for UNIX systems</c>
<l>    Size := Size*1.25</l>
<l>    AllowedFontSizes := [11,14,17,20,25,34]</l>
<l>    if (find(AllowedFontSizes,Size)=-1)</l>
<l>        Distances := abs(AllowedFontSizes-Size)</l>
<l>        tuple_sort_index (Distances, Indices)</l>
<l>        Size := AllowedFontSizes[Indices[0]]</l>
<l>    endif</l>
<l>    if (Font = 'mono' or Font = 'Courier')</l>
<l>        Font := 'courier'</l>
<l>    elseif (Font = 'sans')</l>
<l>        Font := 'helvetica'</l>
<l>    elseif (Font = 'serif')</l>
<l>        Font := 'times'</l>
<l>    endif</l>
<l>    if (Bold='true')</l>
<l>        Bold := 'bold'</l>
<l>    elseif (Bold='false')</l>
<l>        Bold := 'medium'</l>
<l>    else</l>
<l>        Exception := 'Wrong value of control parameter Bold'</l>
<l>        throw (Exception)</l>
<l>    endif</l>
<l>    if (Slant='true')</l>
<l>        if (Font='times')</l>
<l>            Slant := 'i'</l>
<l>        else</l>
<l>            Slant := 'o'</l>
<l>        endif    </l>
<l>    elseif (Slant='false')</l>
<l>        Slant := 'r'</l>
<l>    else</l>
<l>        Exception := 'Wrong value of control parameter Slant'</l>
<l>        throw (Exception)</l>
<l>    endif</l>
<l>    try</l>
<l>        set_font (WindowHandle, '-adobe-' + Font + '-' + Bold + '-' + Slant + '-normal-*-' + Size + '-*-*-*-*-*-*-*')</l>
<l>    catch (Exception)</l>
<l>        throw (Exception)</l>
<l>    endtry</l>
<l>endif</l>
<l>return ()</l>
</body>
<docu id="set_display_font">
<abstract lang="en_US">This procedure sets the text font of the current window with the specified attributes Size, Bold and Slant. 
As font, the font name or one of the strings 'mono', 'sans', 'serif' can be used. 'mono' will be mapped to 'Courier New' on Windows, and to 'courier' on Linux. 'sans' will be mapped to 'Arial' on Windows, and to 'helvetica' on Linux. 'serif' will be mapped to 'Times New Roman' on Windows, and to 'times' on Linux.
It is assumed that following fonts are installed on the system:
Windows: Courier New, Arial, Times New Roman
Linux: courier, helvetica, times
Because fonts are displayed smaller on Linux than on Windows, a scaling factor of 1.25 is used for the font size on Linux systems the get comparable results.
For Linux, only a limited number of font sizes is supported. To get comparable results, it is recommended to use one of the following sizes: 9, 11, 14, 16, 20, 27 (which will be mapped internally on Linux systems to 11, 14, 17, 20, 25, 34)
</abstract>
<alternatives>
<item>set_font</item>
</alternatives>
<attention lang="en_US">It is assumed that following fonts are installed on the system:
Windows: Courier New, Arial, Times New Roman
Linux: courier, helvetica, times
Because fonts are displayed smaller on Linux than on Windows, a scaling factor of 1.25 is used for the font size on Linux systems the get comparable results.
For Linux, only a limited number of font sizes is supported. To get comparable results, it is recommended to use one of the following sizes: 9, 11, 14, 16, 20, 27 (which will be mapped internally on Linux systems to 11, 14, 17, 20, 25, 34)</attention>
