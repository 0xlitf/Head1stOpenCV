<?xml version="1.0" encoding="UTF-8"?>
<hdevelop file_version="1.0" halcon_version="10.0" cs="388364696">
<procedure name="main">
<interface/>
<body>
<l>set_system('border_shape_models','false')</l>
<c>* 最小缺陷面积参数</c>
<l>MinDefectArea := 400</l>
<c>* 合格误差范围</c>
<l>WdiffValue := 3</l>
<l>ADiffValue := 0.1</l>
<c>* 二值化阈值</c>
<l>Threshold := 200  </l>
<c>* 物料匹配限制参数</c>
<l>MinScore := 0.7</l>
<c>* 最小缺陷内径</c>
<l>MinDefectInnerRadian := 30</l>
<c></c>
<c>* 是否采用动态训练模式</c>
<l>IsDynamic := 1</l>
<c>    </c>
<l>dev_update_window ('off')</l>
<l>* Width := 800</l>
<l>* Height := 600</l>
<l>Width := 600</l>
<l>Height := 450</l>
<l>dev_close_window ()</l>
<l>dev_open_window (0, 0, Width, Height, 'white', WindowHandle)</l>
<l>set_draw(WindowHandle, 'margin')</l>
<l>* dev_close_window()</l>
<l>* dev_set_colored(3)</l>
<l>* set_color(WindowHandle, 3)</l>
<c>* ROI参数设置</c>
<c>*roi_1 </c>
<l>roiLTX := 65</l>
<l>roiLTY := 75</l>
<l>roiWidth := 1089</l>
<l>roiHeight := 864</l>
<c>*roi_2无黑点</c>
<l>* roiLTX := 50</l>
<l>* roiLTY := 302</l>
<l>* roiWidth := 1107-roiLTX</l>
<l>* roiHeight := 855-roiLTY</l>
<c>*roi_2有黑点</c>
<l>* roiLTX := 22</l>
<l>* roiLTY := 58</l>
<l>* roiWidth := 485</l>
<l>* roiHeight := 320</l>
<c></c>
<l>* roiLTX := 44</l>
<l>* roiLTY := 69</l>
<l>* roiWidth := 274-roiLTX</l>
<l>* roiHeight := 111-roiLTY</l>
<l>gen_rectangle1(RegionROI, roiLTY, roiLTX, roiLTY+roiHeight, roiLTX + roiWidth)</l>
<l>*     draw_rectangle1(WindowHandle, Row11, Column11, Row2, Column2)</l>
<l>* gen_rectangle1(Rectangle, Row11, Column11, Row2, Column2)</l>
<l>        ModelIDs := []</l>
<l>        gen_empty_obj(ModelRegionsOrigins)</l>
<l>        ModelGrays := []</l>
<l>        ModelWidthAll := []</l>
<l>        ModelHeightAll := []</l>
<l>        ModelIDs := [] </l>
<l>        ModelGrays := []</l>
<l>        gen_empty_obj(ModelRegions)</l>
<l>        tuple_gen_const(80, 0, ObjectID)</l>
<c></c>
<c>  </c>
<c>* 文件保存路径</c>
<l>* ProjectPath := 'E:/VC++  Project/Counter_AutoTraining/data/1203/3point/pic/1'</l>
<l>* TrainPath := ProjectPath</l>
<l>* filePath := 'E:/VC++  Project/Counter/data/20200920_defects/sample' + sampleNo + '/NGHistory'</l>
<c></c>
<l>* filePath := 'E:/VC++  Project/Counter_halcon/20240126'</l>
<l>ProjectPath := 'E:/VC++  Project/Counter_halcon/20250921'</l>
<c></c>
<l>        TrainPath := ProjectPath + '/project'</l>
<l>        filePath :=  ProjectPath + '/image'</l>
<l>*         filePath :=  'E:/VC++  Project/Counter_halcon/20220709/B2' + '/ok-5'</l>
<c>        </c>
<l>        RegionSavePath := TrainPath</l>
<l>        ModelIDSavePath := TrainPath</l>
<c>        </c>
<c></c>
<c>*        * 获取 halcon 标定板比例系数</c>
<l>*          read_image(ImageCalib, filePath+'/0.png')</l>
<l>*          get_image_size(ImageCalib, imgWidth, imgHeight)</l>
<l>*          dev_set_part (0, 0, imgHeight - 1, imgWidth - 1)</l>
<l>*          dev_display (ImageCalib)</l>
<c>         </c>
<l>*          get_calib_factor (ImageCalib, scale_factor)</l>
<c>        </c>
<l>*         StartThresh := 128</l>
<l>*         DeltaThresh := 10</l>
<l>*         MinThresh := 18</l>
<l>*         Alpha := 1.9</l>
<l>*         MinContLength := 10</l>
<l>*         MaxDiamMarks := 100        </l>
<l>*         StartCamPar := [0.008,0,0.000004,0.000004,640,512,1280,1024]</l>
<c>**          read_cam_par ('E:/VC++  Project/Counter_halcon/camera_parameters.dat', CamParam)</c>
<l>*         stop()</l>
<c></c>
<c></c>
<c></c>
<l>        tuple_gen_const(80, 0, TrainTimes)</l>
<l>        ModelIDs := []</l>
<l>        gen_empty_obj(ModelRegionsOrigins)</l>
<l>        ModelGrays := []</l>
<l>        ModelWidthAll := []</l>
<l>        ModelHeightAll := []</l>
<l>        ModelIDs := [] </l>
<l>        ModelGrays := []</l>
<l>        gen_empty_obj(ModelRegions)</l>
<c>        </c>
<c>        </c>
<l>        list_files (TrainPath, ['files','follow_links'], ImageFiles)</l>
<l>        tuple_regexp_select (ImageFiles, ['\\.(tif|tiff|gif|bmp|jpg|jpeg|jp2|png|pcx|pgm|ppm|pbm|xwd|ima)$','ignore_case'], ImageFiles)</l>
<l>        for index := 0 to |ImageFiles| - 1 by 1</l>
<l>            tuple_sort(ImageFiles, ImageFiles)</l>
<l>            read_image (ModelImage, ImageFiles[index])</l>
<l>            get_image_size(ModelImage, imgWidth, imgHeight)</l>
<l>            dev_set_part (0, 0, imgHeight - 1, imgWidth - 1)</l>
<c>            ** zoom_image_size(ModelImage, ModelImage, Width, Height, 'constant')</c>
<c>        </c>
<c>            **invert_image(ModelImage, ModelImage)</c>
<l>            dev_display (ModelImage)</l>
<c>            * colors and other settings for the visualization</c>
<l>            dev_set_color ('green')</l>
<l>            dev_set_draw ('margin')</l>
<l>            dev_set_line_width (3)</l>
<l>            set_display_font (WindowHandle, 14, 'sans', 'true', 'false')</l>
<c>            </c>
<l>            count_channels(ModelImage, Channels)</l>
<l>            if(Channels=3)</l>
<l>                rgb1_to_gray(ModelImage, ModelImage)</l>
<l>            endif</l>
<c>**            draw_rectangle2(WindowHandle, Row1, Column1, Phi, Length1, Length2)</c>
<c>**             gen_rectangle2(Domain, Row1, Column1, Phi, Length1, Length2)</c>
<l>            reduce_domain(ModelImage, RegionROI, ImageReduced)</l>
<c>        **     ModelID := 2</c>
<c>            * 1.训练模型</c>
<c>        **     generate_shape_model_gray(ModelImage, RegionROI, ModelRegionsOrigin, WindowHandle, ModelWidthAll, ModelHeightAll, Threshold, ModelID, ModelWidth, ModelHeight, ModelArea, ModelGrayVal, isTrained)</c>
<c>        **     generate_shape_model(ModelImage, RegionROI, ModelRegionsOrigin, WindowHandle, ModelWidthAll, ModelHeightAll, Threshold, ModelID, ModelWidth, ModelHeight, ModelArea, isTrained)</c>
<c>        **     generate_shape_model_transparent (ModelImage, ImageBG, RegionROI, ModelRegionsOrigin, WindowHandle, ModelWidthAll, ModelHeightAll, Threshold, ModelID, ModelWidth, ModelHeight, ModelArea, isTrained)</c>
<l>            generate_shape_model_dynamic (ImageReduced, RegionROI, ModelRegions, ModelRegionsOrigin, WindowHandle, ModelIDs, ModelWidthAll, ModelHeightAll, ModelGrays, Threshold, WdiffValue, IsDynamic, ModelID, ModelWidth, ModelHeight, ModelArea, ModelGrayVal, isTrained)</l>
<l>            dump_window_image(hImage, WindowHandle)</l>
<l>            zoom_image_size(hImage, hImage, imgWidth, imgHeight, 'constant')</l>
<c>            </c>
<c>        *+     find_shape_model (ModelImage, ModelIDs, 0, rad(360), 0.7, 2, 0.5, 'least_squares_high', [4,1], 0.9, RowCheck, ColumnCheck, AngleCheck, Score)</c>
<c>            </c>
<l>            if (isTrained = 1)</l>
<c>                * isTrained 为1是第一次训练，2是已经训练过，0表示未训练成功 </c>
<l>                ModelWidthAll := [ModelWidthAll, ModelWidth]</l>
<l>                ModelHeightAll := [ModelHeightAll, ModelHeight]</l>
<l>                ModelIDs := [ModelIDs, ModelID]</l>
<l>                ModelGrays := [ModelGrays, ModelGrayVal]</l>
<c>                * translate measurement ROIs to lie on XLD model (without clipping!)</c>
<l>                find_scaled_shape_models(ModelImage, ModelID, 0, rad(360), 0.5, 1.5, MinScore, 1, 0.2, 'least_squares', 9, 0.9, RowCheck, ColumnCheck, AngleCheck, Scale, Score, Model)</l>
<c>**                 find_shape_models (ModelImage, ModelID, 0, rad(360), MinScore, 1, 0.2, 'least_squares', 0, 0.9, RowCheck, ColumnCheck, AngleCheck, Score, Model)</c>
<l>                get_system ('clip_region', OriginalClipRegion)</l>
<l>                set_system ('clip_region', 'false')</l>
<l>                move_region(ModelRegionsOrigin, ModelRegionsOrigin, imgHeight/2-RowCheck, imgWidth/2-ColumnCheck)</l>
<c>    **             move_region(ModelRegionsOrigin, ModelRegionsOrigin, -RowCheck, -ColumnCheck)</c>
<l>                concat_obj(ModelRegions, ModelRegionsOrigin, ModelRegions)</l>
<c></c>
<c>                * 验证训练模型匹配准确性</c>
<l>                if (|Score| &gt; 0)</l>
<l>                    for i := 0 to |Score| - 1 by 1</l>
<c>                        * step 3: determine the affine transformation</c>
<c>**                             select_obj(ModelRegions, SingleModelRegionsOrigin, ModelID + 1)       </c>
<c>                        ** 旋转xld轮廓</c>
<l>                        get_shape_model_contours (ModelContours, ModelID, 1)</l>
<l>                        vector_angle_to_rigid (0, 0, 0, RowCheck[i], ColumnCheck[i], AngleCheck[i], HomMat2D)</l>
<l>                        affine_trans_contour_xld (ModelContours, ModelTrans, HomMat2D)</l>
<c>    **                     area_center_points_xld(ModelTrans, Area1, Row, Column)</c>
<c>                        </c>
<c>                        ** 旋转区域</c>
<l>                        vector_angle_to_rigid (imgHeight/2, imgWidth/2, 0, RowCheck[i], ColumnCheck[i], AngleCheck[i], MovementOfObject)</l>
<c>                        * 如果模版有缩放，则激活该句代码</c>
<l>                        hom_mat2d_scale (MovementOfObject, Scale[i], Scale[i], RowCheck[i], ColumnCheck[i], MovementOfObject)</l>
<l>                        affine_trans_region(ModelRegionsOrigin, RegionAffineTrans, MovementOfObject, 'false')</l>
<l>                        dev_display(ModelImage)</l>
<l>                        dev_set_color('green')</l>
<l>                        dev_display(RegionAffineTrans)</l>
<l>                        dev_set_color('red')</l>
<l>                        dev_display(ModelTrans)</l>
<c>                        </c>
<l>                        smallest_rectangle1(RegionAffineTrans, Row12, Column12, Row21, Column21)</l>
<l>                        crop_rectangle1(ModelImage, ImagePart1, Row12, Column12, Row21, Column21)</l>
<l>                        write_image(hImage, 'jpeg', 0,  TrainPath + '/trainImg_'+ index)</l>
<l>                        write_image(ImagePart1, 'jpeg', 0,  TrainPath + '/cropImg_'+ index)</l>
<l>                        disp_message(WindowHandle, '创建模版成功！ ', 'window', -1, -1, 'green', 'true')</l>
<l>                        disp_continue_message (WindowHandle, 'black', 'true')</l>
<l>                        stop()</l>
<l>                    endfor  </l>
<l>                elseif(ObjNum &gt; 0)</l>
<l>                    disp_message (WindowHandle, 'match no object: ' + time$'.4' + ' ms', 'window', 60, -1, 'red', 'false')</l>
<l>                    wait_seconds(0.5)</l>
<l>                endif</l>
<l>            elseif(isTrained = 3)</l>
<l>                TrainTimes[ModelID] := TrainTimes[ModelID] + 1</l>
<l>                disp_continue_message (WindowHandle, 'black', 'true')</l>
<l>                stop ()</l>
<l>                if(ModelID = 2)</l>
<l>                    stop()</l>
<l>                endif</l>
<l>            endif</l>
<c>        </c>
<l>        endfor</l>
<c>        </c>
<l>        Index := 1</l>
<l>        for I := 0 to |ModelWidthAll|-1 by 1</l>
<l>            select_obj(ModelRegions, ModelRegionsSave, I+1)</l>
<l>            write_region(ModelRegionsSave, TrainPath + '/region_' + Index + '.reg')</l>
<l>            write_shape_model(ModelIDs[I], TrainPath + '/model_' + Index + '.shm')</l>
<l>            disp_message(WindowHandle, 'model_' + I +' 训练完成！', 'window', -1, -1, 'magenta', 'true')</l>
<l>            Index := Index + 1</l>
<l>            disp_continue_message (WindowHandle, 'black', 'true')</l>
<l>            stop ()</l>
<l>        endfor</l>
<c>        **             tuple_gen_const(2, 22, ModelGrays)</c>
<l>            write_tuple(ModelGrays, TrainPath + '/thresh.tup')</l>
<c>                    </c>
<c>                </c>
<c>        </c>
<c>            </c>
<l>        clear_all_shape_models()</l>
<l>        stop ()</l>
<c></c>
<c>        </c>
<c>        * 在检测算子里读取模版model 和区域region</c>
<c>        * 设置超出边界的目标也可以找到</c>
<l>        set_system('border_shape_models', 'true')</l>
<l>        set_system ('timer_mode', 'performance_counter')</l>
<c>        </c>
<l>        list_files (ModelIDSavePath, ['files','follow_links'], Files)</l>
<l>        ModelIDs := []</l>
<l>        tuple_regexp_select (Files, ['\\.(shm)$','ignore_case'], ModelFiles)</l>
<l>        for Index := 0 to |ModelFiles|-1 by 1</l>
<l>            path := ModelFiles[Index]</l>
<l>            read_shape_model(path, ModelID)</l>
<l>            get_shape_model_params(ModelID, NumLevels, AngleStart, AngleExtent, AngleStep, ScaleMin, ScaleMax, ScaleStep, Metric, MinContrast)</l>
<l>            set_shape_model_param(ModelID, 'timeout', -1)</l>
<l>            tuple_concat(ModelIDs, ModelID, ModelIDs)</l>
<c>            </c>
<l>        endfor</l>
<c>        </c>
<c>        * 2. 读取模板和区域</c>
<l>        list_files (RegionSavePath, ['files','follow_links'], Files)</l>
<l>        gen_empty_obj(ModelRegions)</l>
<l>        tuple_regexp_select (Files, ['\\.(reg)$','ignore_case'], RegionFiles)</l>
<l>        for Index := 0 to |RegionFiles|-1 by 1</l>
<l>            path := RegionFiles[Index]</l>
<l>            read_region(ModelRegionsOrigin, path)</l>
<c>**             move_region(ModelRegionsOrigin, ModelRegionsOrigin, 120, 160)</c>
<l>            concat_obj(ModelRegions, ModelRegionsOrigin, ModelRegions)</l>
<l>        endfor</l>
<c>        </c>
<c>        * 3. 读取区域灰度值</c>
<l>        ModelGrays := []</l>
<l>        list_files (RegionSavePath, ['files','follow_links'], Files)</l>
<l>        tuple_regexp_select (Files, ['\\.(tup)$','ignore_case'], RegionFiles)</l>
<l>        for Index := 0 to |RegionFiles|-1 by 1</l>
<l>            path := RegionFiles[Index]</l>
<l>            read_tuple(path, ModGray)</l>
<l>            tuple_concat(ModelGrays, ModGray, ModelGrays)</l>
<l>        endfor</l>
<c></c>
<c>        * 4. 读取模板图像</c>
<l>*         list_files (RegionSavePath, ['files','follow_links'], Files)</l>
<l>*         gen_empty_obj(ModelImages)</l>
<l>*         tuple_regexp_select (Files, ['cropImg_0.jpg','ignore_case'], RegionFiles)</l>
<l>*         for Index := 0 to |RegionFiles|-1 by 1</l>
<l>*             path := RegionFiles[Index]</l>
<l>*             read_image(ModelImage, path)</l>
<c>**             move_region(ModelRegionsOrigin, ModelRegionsOrigin, 120, 160)</c>
<l>*             concat_obj(ModelImages, ModelImage, ModelImages)</l>
<l>*         endfor</l>
<c>   </c>
<c></c>
<c>* 3.检测缺陷</c>
<c>* Image Acquisition 01: Code generated by Image Acquisitions 01</c>
<c></c>
<l>list_files (filePath, ['files','follow_links'], ImageFiles)</l>
<l as_id="image_acquisition" as_name="Image Acquisition 01" as_grp="[1,3]" as_ord="1">tuple_regexp_select (ImageFiles, ['\\.(tif|tiff|gif|bmp|jpg|jpeg|jp2|png|pcx|pgm|ppm|pbm|xwd|ima)$','ignore_case'], ImageFiles)</l>
<l>tuple_sort(ImageFiles, ImageFiles)</l>
<l>* tuple_regexp_replace(ImageFiles, ['(.*)\\*.jpg', 'replace_all'], '*\\$6.jpg', ImageFiles2)</l>
<l>for index := 0 to |ImageFiles| - 1 by 1 </l>
<l>    dev_set_color ('red')</l>
<l>    read_image (SearchImage, ImageFiles[index]) </l>
<l>*     read_image (SearchImage2, ImageFiles[index+1]) </l>
<l>*     sub_image(SearchImage2, SearchImage, ImageSub, 1, 128)</l>
<l>*     scale_image_max(ImageSub, ImageScaleMax)</l>
<c>    </c>
<l>*     invert_image(SearchImage, SearchImage)</l>
<c>    </c>
<l>    get_image_size(SearchImage, imgWidth, imgHeight)</l>
<l>    dev_set_part (0, 0, imgHeight - 1, imgWidth - 1)</l>
<l>    dev_display(SearchImage)</l>
<l>    count_channels(SearchImage, Channels)</l>
<l>    if(Channels&gt;1)</l>
<l>        rgb1_to_gray(SearchImage, SearchImage)</l>
<l>*         decompose3(SearchImage, Image1, Image2, Image3)</l>
<l>    endif</l>
<l>    dev_display(SearchImage)</l>
<l>    disp_message (WindowHandle, 'Index:' + index, 'window', 12, 12, 'black', 'true')</l>
<c>    * 2.检测图片，输出结果isDefect = 0合格，1不合格</c>
<l>    count_seconds (start)</l>
<l>*     search_shape_model_transparent (SearchImage, RegionROI, WindowHandle, ModelIDs, RegionSavePath, Threshold, WdiffValue, NewRow, NewColumn, NewWidth, NewArea, isDefect)</l>
<l>*     search_shape_model (SearchImage, RegionROI, ModelRegions, WindowHandle, ModelIDs, Threshold, WdiffValue, MinScore, MinDefectInnerRadian, NewRow, NewColumn, NewWidth, NewArea, isDefect)</l>
<l>    search_shape_model_gray (SearchImage, RegionROI, ModelRegions, ObjRegions, WindowHandle, ModelIDs, ModelGrays, Threshold, WdiffValue, MinScore, MinDefectInnerRadian, NewRow, NewColumn, NewWidth, NewArea, Model, isDefect)</l>
<l>*     shape_trans(ObjRegions, RegionTrans, 'rectangle1')</l>
<l>*     reduce_domain(SearchImage, RegionTrans, ImageReduced1)</l>
<l>*     crop_domain(ImageReduced1, ImagePart)</l>
<l>    count_seconds (end)</l>
<l>*     for i := 0 to |isDefect|-1 by 1</l>
<l>*         if (isDefect[i] = 0)</l>
<l>*             disp_message (WindowHandle, 'ObjectID:' + ObjectID[Model[i]], 'window', NewRow[i], NewColumn[i], 'black', 'true')</l>
<l>*         endif</l>
<l>*     endfor</l>
<l>    disp_message (WindowHandle, 'Index:' + index + '   time: ' + (end-start), 'window', 12, 12, 'black', 'true')</l>
<l>*     disp_message (WindowHandle, ImageFiles[index], 'window', 32, 12, 'black', 'true')</l>
<l>*     disp_continue_message (WindowHandle, 'black', 'true')</l>
<l>*     wait_seconds(0.03)</l>
<l>    if(|isDefect| &gt;1)</l>
<l>        stop()</l>
<l>    endif</l>
<l>    for J := 0 to |isDefect|-1 by 1</l>
<l>        if (isDefect[J] &lt; 2)</l>
<l>            stop()</l>
<l>            break</l>
<l>        endif</l>
<c>        </c>
<l>*         if (isDefect[I] = 3)</l>
<l>*             index := index -2</l>
<l>*         endif</l>
<l>    endfor</l>
<l>*     index := index +1</l>
<l>*     stop()</l>
<l>endfor</l>
<c>* -------------------  end of the application  -----------------</c>
<c>* clean up</c>
<l>* clear_all_shape_models()</l>
<l>dev_update_window ('on')</l>
<l>disp_message(WindowHandle, 'Detect Finish! ', 'window', -1, -1, 'red', 'true')</l>
<c></c>
<c></c>
<c></c>
</body>
<docu id="main">
<parameters/>
</docu>
</procedure>
<procedure name="dev_display_shape_matching_results">
<interface>
<ic>
<par name="ModelID"/>
<par name="Color"/>
<par name="Row"/>
<par name="Column"/>
<par name="Angle"/>
<par name="ScaleR"/>
<par name="ScaleC"/>
<par name="Model"/>
</ic>
</interface>
<body>
<c>* This procedure displays the results of Shape-Based Matching.</c>
<c>* </c>
<l>NumMatches := |Row|</l>
<l>if (NumMatches&gt;0)</l>
<l>    if (|ScaleR|=1)</l>
<l>        tuple_gen_const (NumMatches, ScaleR, ScaleR)</l>
<l>    endif</l>
<l>    if (|ScaleC|=1)</l>
<l>        tuple_gen_const (NumMatches, ScaleC, ScaleC)</l>
<l>    endif</l>
<l>    if (|Model|=0)</l>
<l>        tuple_gen_const (NumMatches, 0, Model)</l>
<l>    elseif (|Model|=1)</l>
<l>        tuple_gen_const (NumMatches, Model, Model)</l>
<l>    endif</l>
<l>    for Index := 0 to |ModelID|-1 by 1</l>
<l>        get_shape_model_contours (ModelContours, ModelID[Index], 1)</l>
<l>        dev_set_color (Color[Index%|Color|])</l>
<l>        for Match := 0 to NumMatches-1 by 1</l>
<l>            if (Index=Model[Match])</l>
<l>                hom_mat2d_identity (HomMat2DIdentity)</l>
<l>                hom_mat2d_scale (HomMat2DIdentity, ScaleR[Match], ScaleC[Match], 0, 0, HomMat2DScale)</l>
<l>                hom_mat2d_rotate (HomMat2DScale, Angle[Match], 0, 0, HomMat2DRotate)</l>
<l>                hom_mat2d_translate (HomMat2DRotate, Row[Match], Column[Match], HomMat2DTranslate)</l>
<l>                affine_trans_contour_xld (ModelContours, ContoursAffinTrans, HomMat2DTranslate)</l>
<l>                dev_display (ContoursAffinTrans)</l>
<l>            endif</l>
<l>        endfor</l>
<l>    endfor</l>
<l>endif</l>
<l>return ()</l>
</body>
<docu id="dev_display_shape_matching_results">
<abstract lang="en_US">The procedure dev_display_shape_matching_results displays the results of Shape-Based Matching. 

In ModelID, the shape models for which results should be displayed are passed. This parameter typically contains the same values that were passed to the operator that was used to find the instances of the shape model.

Color is a tuple of colors that will be used for the visualization. If Color contains only one element, all found instances are displayed in this color. If Color is a tuple that  contains multiple elements,  the specified colors are used cyclically for the visualization of the matching results.

Row, Column, and Angle contain the position and rotation information of the found instances of the shape models.

ScaleR and ScaleC contain the scale of the found instances of the shape model. If find_shape_model(s) was used to find the instances of the shape model, ScaleR and ScaleC should be set to 1.0. If find_scaled_shape_model(s) was used to find the instances of the shape model, ScaleR contains the scale of the found instances and ScaleC should be set to 1.0. If find_aniso_shape_model(s) was used to find the instances of the shape model, ScaleR and ScaleC contain the respective anisotropic scales of the found instances.

The elements of Model describe to which element of the tuple ModelID the elements of Row, Column, Angle, ScaleR, and ScaleC refer to. The elements of Model are indices into the tuple ModelID, i.e., they can contain values from 0 to |ModelID|-1.  Hence, a value of 0 in an element of Model corresponds to an instance of the first model in ModelID. If only one model is given in ModelID, Model can be set to 0. Otherwise, the output of the operators find_shape_models, find_scaled_shape_models, or find_aniso_shape_models can be used directly.
</abstract>
<chapters>
<item>Matching</item>
<item>Shape-Based</item>
</chapters>
<chapters lang="de_DE">
<item>Matching</item>
<item>Shape-Based</item>
</chapters>
<chapters lang="en_US">
<item>Matching</item>
<item>Shape-Based</item>
</chapters>
<example lang="en_US">read_image(Image,'mreut')
gen_rectangle1(Rectangle1, 30, 20, 100, 200)
gen_rectangle1 (Rectangle2, 130, 120, 200, 200)
reduce_domain (Image, Rectangle1, ImageReduced1)
reduce_domain (Image, Rectangle2, ImageReduced2)
create_scaled_shape_model(ImageReduced1, 'auto', -0.39, 0.79,
                          'auto', 0.9, 1.1, 'auto', 'auto',
                          'use_polarity', 'auto', 'auto', ModelID1)
create_scaled_shape_model(ImageReduced2, 'auto', -0.39, 0.79,
                          'auto', 0.9, 1.1, 'auto', 'auto',
                          'use_polarity', 'auto', 'auto', ModelID2)
find_scaled_shape_models (Image, [ModelID1,ModelID2], -0.39, 0.78,
                          0.9, 1.1, 0.5, 2, 0.5, 'least_squares', 0, 0.9,
                          Row, Column, Angle, Scale, Score, Model)
dev_display_shape_matching_results ([ModelID1,ModelID2], ['red','green'],
                          Row, Column, Angle, Scale, 1.0, Model)
</example>
<keywords lang="de_DE">
<item>Ergebnisse des formbasierten Matchings anzeigen</item>
</keywords>
<keywords lang="en_US">
